# =====================================================================
# EquiLink - Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to source control.
# =====================================================================

# ---- Operating mode ----
# DEMO_MODE=1  -> No real SMS/email is sent. Everything is simulated and
#                 written to data/outbox/ so you can inspect the messages.
# DEMO_MODE=0  -> Real SMS + real SMTP email are sent (requires creds below).
DEMO_MODE=1

# ---- SMS provider: choose one of "africastalking", "twilio", or "none" ----
SMS_PROVIDER=none

# Africa's Talking (recommended for NG/CM/CG)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=

# Twilio (fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="EquiLink <noreply@equilink.africa>"

# Where notification emails about unregistered candidates are sent
DISABILITY_REGISTRY_EMAIL=registry-demo@example.org

# ---- Application HR contacts (where job applications are emailed) ----
# In demo mode this is overridden by the email addresses inside data/jobs.csv
APPLICATION_FROM_NAME="EquiLink Talent Desk"

# ---- Privacy ----
# Salt used to hash phone numbers in audit logs. Generate a random string.
PII_HASH_SALT=change-me-to-a-long-random-string

# ---- Job sources ----
# Set to 1 to also fetch live remote jobs from RemoteOK (free, no key needed)
USE_REMOTEOK=1

# SerpApi google_jobs (free tier: 50 searches/month).
# Get an API key at https://serpapi.com/. Keep it OUT of source control.
SERPAPI_API_KEY=
SERPAPI_ENABLED=1
# Hard cap on live calls per UTC day to protect your free quota.
SERPAPI_MAX_CALLS_PER_DAY=10

# ---- LLM rerank (local Gemma via Ollama) ----
# Asks the model: "can this disabled candidate perform the core tasks of
# the job?". Used as a final sanity check on the top-N rule-based results.
# Runs locally — no API key needed. Requires:
#   1) Ollama installed and the daemon running: https://ollama.com
#   2) The model pulled:                    ollama pull gemma3:4b
#   3) The Python client installed:         pip install ollama
LLM_RERANK_ENABLED=0
LLM_MODEL=gemma3:4b
# Per-(candidate,job) responses are cached on disk, so a single submission
# uses at most TOP_N_JOBS calls (5 by default) and reruns are free.
LLM_MAX_CALLS_PER_DAY=200
